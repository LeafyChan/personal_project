{
  "_comment": "Edit this file to change what gets extracted/validated. No code changes needed.",

  "required_fields": [
    "vendor_name",
    "vendor_gstin",
    "invoice_number",
    "invoice_date",
    "taxable_amount",
    "total_gst_amount",
    "total_amount"
  ],

  "optional_fields": [
    "buyer_name",
    "buyer_gstin",
    "place_of_supply",
    "cgst_amount",
    "sgst_amount",
    "igst_amount",
    "hsn_codes",
    "line_items",
    "payment_due_date",
    "po_number",
    "currency_code",
    "tax_label_raw"
  ],

  "field_types": {
    "vendor_name": "string",
    "vendor_gstin": "gstin",
    "buyer_name": "string",
    "buyer_gstin": "gstin",
    "invoice_number": "string",
    "invoice_date": "date",
    "payment_due_date": "date",
    "taxable_amount": "amount",
    "cgst_amount": "amount",
    "sgst_amount": "amount",
    "igst_amount": "amount",
    "total_gst_amount": "amount",
    "total_amount": "amount",
    "place_of_supply": "string",
    "hsn_codes": "list",
    "line_items": "list",
    "po_number": "string",
    "currency_code": "string",
    "tax_label_raw": "string"
  },

  "validation_rules": {
    "gstin_regex": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$",
    "amount_reconciliation_tolerance": 2.0,
    "max_invoice_age_days": 1825,
    "date_formats": ["%d/%m/%Y", "%d-%m-%Y", "%Y-%m-%d", "%d %b %Y", "%d-%b-%Y", "%d.%m.%Y"],
    "expected_currency": "INR",
    "recognized_currency_codes": ["INR", "RS", "RS.", "₹", "USD", "$", "EUR", "€", "GBP", "£"]
  },

  "confidence_thresholds": {
    "ocr_text_min_confidence": 65,
    "auto_pass_min_confidence": 85,
    "needs_review_below": 70
  },

  "invoice_type_hints": {
    "_comment": "Optional per-vendor-type overrides, e.g. some vendors omit place_of_supply. Add entries as you encounter new formats.",
    "default": {
      "skip_fields": []
    },
    "retail_pos_receipt": {
      "skip_fields": ["po_number", "place_of_supply"]
    }
  }
}
